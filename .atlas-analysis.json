  "keyFeatures": [
    "Astro 5 static site generation with TypeScript",
    "GSAP animations with ScrollTrigger and Lenis smooth scrolling",
    "Bilingual support (Spanish/English) with i18n routing",
    "eGO Real Estate API integration for property data",
    "Leaflet maps for property locations",
    "Responsive design with premium minimalist aesthetic",
    "Automated deployment via GitHub Actions",
    "Lead management with PHP proxy backend"
  ],
  "publicApiSurface": [
    "Property interface (id, egoId, title, location, type, bedrooms, bathrooms, size, price, images, coords)",
    "ApiCore.request() - API request handler with retry logic",
    "textRevealAnimation() - GSAP text reveal utility",
    "textSwipeAnimation() - GSAP text swipe utility",
    "useTranslatedPath() - i18n path helper",
    "getLangFromUrl() - Extract language from URL",
    "useTranslations() - Get translations for current language",
    "BaseLayout component - Main layout with Lenis and page transitions",
    "Navigation component - Header with language switcher",
    "PropertyGrid component - Filterable property listings",
    "PropertyMap component - Leaflet map integration"
  ]
}
